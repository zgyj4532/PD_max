# Copy this file to .env and fill in secrets before running the app

# MySQL / 数据库（在 docker-compose 中，后端容器内可使用容器名 mysql）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=pd_max_db
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_CHARSET=utf8mb4

# 上传目录（可选）
UPLOAD_DIR=uploads

# JWT 配置
JWT_SECRET_KEY=change_this_to_a_strong_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 默认管理员（首次启动会根据这些值创建管理员账号）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# LLM（采购建议）配置
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-6

# VLM（报价表识别）配置
VLM_API_KEY=
VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-max-latest

# 可选：Qwen/Dashscope 备用变量（部分服务读取这些名称）
QWEN_API_KEY=
DASHSCOPE_API_KEY=
